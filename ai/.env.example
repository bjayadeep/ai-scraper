# SMTP Credentials (Required for email delivery)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
EMAIL_TO=recipient_email@gmail.com
EMAIL_FROM=your_email@gmail.com

# Claude AI Filter (Primary AI validation)
CLAUDE_API_KEY=sk-ant-api03-...
USE_AI_FILTER=true

# Company Cooldown Filter (14 days = alternate week frequency per company)
COMPANY_COOLDOWN_DAYS=14

# Database Connection (Leave empty for SQLite local fallback, or set for Neon PostgreSQL)
DATABASE_URL=postgres://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

